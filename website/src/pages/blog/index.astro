---
import { getCollection } from "astro:content";
import Footer from "../../components/Footer.astro";
import Nav from "../../components/Nav.astro";
import Layout from "../../layouts/Layout.astro";
import { formatDate } from "../../utils/date";

const posts = (await getCollection("blog", ({ data }) => data.draft !== true)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout title="Blog — vibe-replay" description="Updates, guides, and stories from the vibe-replay project.">
  <Nav active="blog" />

  <main class="min-h-screen pt-16 pb-20 px-6">
    <div class="max-w-4xl mx-auto">
      <!-- Header -->
      <header class="mb-16 animate-slide-up">
        <h1 class="text-4xl md:text-5xl font-bold mb-3">
          <span class="bg-gradient-to-r from-accent via-emerald-400 to-cyan-400 bg-clip-text text-transparent">vibe-replay</span>
          <span class="text-text-primary"> blog</span>
        </h1>
        <p class="text-text-secondary text-lg">Stories, insights, and updates from building with AI.</p>
      </header>

      <!-- Post list -->
      <div class="flex flex-col gap-8">
        {posts.map((post, i) => (
          <a href={`/blog/${post.id}/`} class="group block">
            <article class="rounded-2xl border border-border bg-surface-1/40 hover:border-accent/40 hover:bg-surface-1 transition-all duration-300 overflow-hidden">
              {/* Cover image — constrained height */}
              {post.data.cover && (
                <div class="relative overflow-hidden h-48 sm:h-56 md:h-64">
                  <img
                    src={post.data.cover}
                    alt={post.data.title}
                    class="w-full h-full object-cover object-top group-hover:scale-[1.02] transition-transform duration-500"
                    loading={i === 0 ? "eager" : "lazy"}
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-surface-1/90 via-surface-1/20 to-transparent" />
                </div>
              )}
              {/* Content */}
              <div class="p-6 md:p-8">
                <div class="flex items-center gap-3 text-sm text-text-muted mb-3">
                  <a href={post.data.authorUrl} target="_blank" rel="noopener" class="text-text-secondary hover:text-accent transition-colors" onclick="event.stopPropagation()">
                    {post.data.author}
                  </a>
                  <span class="w-1 h-1 rounded-full bg-text-muted" />
                  <time datetime={post.data.date.toISOString().split("T")[0]}>
                    {formatDate(post.data.date)}
                  </time>
                  <span class="w-1 h-1 rounded-full bg-text-muted" />
                  <span>{post.data.readTime}</span>
                </div>
                <h2 class="text-2xl md:text-3xl font-bold mb-3 group-hover:text-accent transition-colors leading-tight">
                  {post.data.title}
                </h2>
                <p class="text-text-secondary leading-relaxed text-base md:text-lg">
                  {post.data.excerpt}
                </p>
                <div class="mt-5 inline-flex items-center gap-2 text-accent text-sm font-medium group-hover:gap-3 transition-all">
                  Read more
                  <span class="transition-transform group-hover:translate-x-1">&rarr;</span>
                </div>
              </div>
            </article>
          </a>
        ))}
      </div>

      {posts.length === 0 && (
        <p class="text-text-muted text-center py-20">No posts yet. Check back soon.</p>
      )}
    </div>
  </main>

  <Footer />
</Layout>
