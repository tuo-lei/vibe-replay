---
import Footer from "../components/Footer.astro";
import GitHubStar from "../components/GitHubStar.astro";
import Layout from "../layouts/Layout.astro";
---

<Layout title="Profile - vibe-replay" description="Manage your shared AI coding session replays. View storage usage, cloud replays, and GitHub Gists.">
  <div class="min-h-screen flex flex-col">
    <!-- Header (matches main page nav) -->
    <nav class="border-b border-border/50 px-6 py-3">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-4">
          <a href="/" class="font-mono font-bold text-sm hover:opacity-80 transition-opacity bg-gradient-to-r from-accent via-emerald-400 to-cyan-400 bg-clip-text text-transparent">vibe-replay</a>
          <span class="text-border hidden sm:inline">|</span>
          <span class="text-text-secondary text-sm hidden sm:inline">Profile</span>
        </div>
        <div class="flex items-center gap-3">
          <GitHubStar />
          <!-- Auth -->
          <div id="auth-container" style="display:none">
            <button id="auth-login" style="display:none" class="inline-flex items-center gap-1.5 h-8 px-3 rounded-md bg-[#24292f] hover:bg-[#32383f] text-white text-xs font-medium transition-colors cursor-pointer border border-white/10">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Sign in
            </button>
            <div id="auth-user" style="display:none" class="relative">
              <button id="auth-avatar-btn" class="flex items-center justify-center w-8 h-8 rounded-full border border-border/60 hover:border-accent/70 transition-all cursor-pointer overflow-hidden">
                <img id="auth-avatar" class="w-full h-full rounded-full object-cover" alt="" />
              </button>
              <div id="auth-dropdown" class="hidden absolute right-0 top-full mt-2 min-w-[160px] bg-surface-1 border border-border rounded-lg shadow-lg py-1 z-50">
                <a id="auth-username" href="/profile" class="block px-3 py-2 text-xs text-text-secondary border-b border-border truncate hover:text-accent transition-colors"></a>
                <button id="auth-logout" class="w-full text-left px-3 py-2 text-sm text-text-secondary hover:text-red-400 hover:bg-surface-2 transition-colors cursor-pointer">Logout</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main content -->
    <main class="flex-1 max-w-6xl mx-auto w-full px-6 py-10">
      <!-- Loading state -->
      <div id="loading" class="text-center py-20">
        <div class="text-text-muted font-mono text-sm animate-pulse">Loading...</div>
      </div>

      <!-- Not logged in state -->
      <div id="signed-out" class="hidden">
        <div class="flex items-center justify-center py-20">
          <div class="rounded-xl border border-border bg-surface-1 p-10 max-w-md text-center">
            <div class="text-4xl mb-4">&#128274;</div>
            <h2 class="text-lg font-semibold text-text-primary mb-2">Sign in required</h2>
            <p class="text-text-muted text-sm mb-6">Sign in with GitHub to manage your shared replays</p>
            <button id="signin-btn" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg bg-[#24292f] hover:bg-[#32383f] text-white text-sm font-medium transition-colors cursor-pointer border border-white/10">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
              Sign in with GitHub
            </button>
          </div>
        </div>
      </div>

      <!-- Signed in content -->
      <div id="profile-content" class="hidden">
        <!-- Page title -->
        <div class="mb-8">
          <h1 class="text-2xl font-bold text-text-primary mb-1">My Replays</h1>
          <p class="text-text-muted text-sm font-mono">Manage your shared replays and storage</p>
        </div>

        <!-- Storage section -->
        <div id="storage-section" class="rounded-xl border border-border bg-surface-1 p-5 mb-8">
          <div class="flex items-center justify-between mb-3">
            <h2 class="text-sm font-semibold text-text-primary">Storage</h2>
            <span id="storage-text" class="text-xs font-mono text-text-muted"></span>
          </div>
          <div class="w-full h-2 rounded-full bg-surface-2 overflow-hidden">
            <div id="storage-bar" class="h-full rounded-full bg-accent transition-all duration-500" style="width: 0%"></div>
          </div>
        </div>

        <!-- Cloud Replays section -->
        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            <h2 class="text-lg font-semibold text-text-primary">Cloud Replays</h2>
            <span id="cloud-count" class="text-xs font-mono px-2 py-0.5 rounded-full bg-surface-2 text-text-muted">0</span>
          </div>
          <div id="cloud-empty" class="hidden rounded-xl border border-border bg-surface-1 p-10 text-center">
            <div class="text-3xl mb-3">&#9729;</div>
            <p class="text-text-muted text-sm">No cloud replays yet</p>
            <p class="text-text-muted text-xs mt-1 font-mono">npx vibe-replay --cloud</p>
          </div>
          <div id="cloud-grid" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-4"></div>
        </div>

        <!-- Gist Replays section -->
        <div class="mb-10">
          <div class="flex items-center gap-2 mb-4">
            <h2 class="text-lg font-semibold text-text-primary">GitHub Gists</h2>
            <span id="gist-count" class="text-xs font-mono px-2 py-0.5 rounded-full bg-surface-2 text-text-muted">0</span>
          </div>
          <div id="gist-empty" class="hidden rounded-xl border border-border bg-surface-1 p-10 text-center">
            <div class="text-3xl mb-3">&#128196;</div>
            <p class="text-text-muted text-sm">No gist replays yet</p>
            <p class="text-text-muted text-xs mt-1 font-mono">npx vibe-replay --gist</p>
          </div>
          <div id="gist-grid" class="hidden grid grid-cols-1 lg:grid-cols-2 gap-4"></div>
        </div>
      </div>
    </main>

    <Footer />
  </div>
</Layout>

<script>
  // --- Helpers ---
  function escapeHtml(s: string): string {
    const div = document.createElement("div");
    div.textContent = s;
    return div.innerHTML;
  }

  function formatDuration(ms: number): string {
    if (!ms) return "";
    const secs = Math.floor(ms / 1000);
    if (secs < 60) return `${secs}s`;
    const mins = Math.floor(secs / 60);
    if (mins < 60) return `${mins}m ${secs % 60}s`;
    const hrs = Math.floor(mins / 60);
    return `${hrs}h ${mins % 60}m`;
  }

  function formatDate(iso: string): string {
    const d = new Date(iso + "Z");
    const now = new Date();
    const diff = now.getTime() - d.getTime();
    const hours = Math.floor(diff / 3600000);
    if (hours < 1) return "just now";
    if (hours < 24) return `${hours}h ago`;
    const days = Math.floor(hours / 24);
    if (days < 30) return `${days}d ago`;
    return d.toLocaleDateString("en-US", { month: "short", day: "numeric" });
  }

  function formatBytes(bytes: number): string {
    if (bytes < 1024) return `${bytes} B`;
    const kb = bytes / 1024;
    if (kb < 1024) return `${kb.toFixed(1)} KB`;
    const mb = kb / 1024;
    return `${mb.toFixed(1)} MB`;
  }

  function formatExpiry(iso: string | null): string {
    if (!iso) return "No expiry";
    const d = new Date(iso + "Z");
    const now = new Date();
    const diff = d.getTime() - now.getTime();
    if (diff < 0) return "Expired";
    const days = Math.ceil(diff / 86400000);
    if (days <= 1) return "Expires today";
    if (days <= 30) return `Expires in ${days}d`;
    return `Expires ${d.toLocaleDateString("en-US", { month: "short", day: "numeric" })}`;
  }

  function visibilityLabel(v: string): string {
    if (v === "public") return "Public";
    if (v === "private") return "Private";
    return "Link only";
  }

  function visibilityColor(v: string): string {
    if (v === "public") return "text-emerald-400 bg-emerald-400/10 border-emerald-400/20";
    if (v === "private") return "text-red-400 bg-red-400/10 border-red-400/20";
    return "text-amber-400 bg-amber-400/10 border-amber-400/20";
  }

  // --- Interfaces ---
  interface CloudReplay {
    id: string;
    storageType: "r2" | "gist";
    gistId: string | null;
    gistUrl: string | null;
    title: string;
    provider: string;
    model: string | null;
    sceneCount: number;
    userPrompts: number;
    toolCalls: number;
    durationMs: number;
    sizeBytes: number;
    visibility: string;
    viewCount: number;
    createdAt: string;
    expiresAt: string | null;
  }

  interface ApiResponse {
    replays: CloudReplay[];
    storage: { used: number; limit: number };
  }

  // --- Card rendering ---
  function createCloudCard(r: CloudReplay): string {
    const safeId = r.id.replace(/[^a-zA-Z0-9_-]/g, "");
    const prompts = parseInt(String(r.userPrompts)) || 0;
    const tools = parseInt(String(r.toolCalls)) || 0;
    const views = parseInt(String(r.viewCount)) || 0;
    const duration = formatDuration(r.durationMs);
    const size = formatBytes(r.sizeBytes || 0);
    const expiry = formatExpiry(r.expiresAt);
    const vis = r.visibility || "unlisted";

    return `
      <div class="rounded-xl border border-border bg-surface-1 p-5" data-replay-id="${safeId}">
        <div class="flex items-start justify-between mb-2">
          <h3 class="font-mono text-sm font-semibold text-text-primary truncate pr-2">${escapeHtml(r.title)}</h3>
          <span class="text-[10px] text-text-muted shrink-0">${escapeHtml(formatDate(r.createdAt))}</span>
        </div>
        <div class="flex items-center gap-2 mb-3">
          ${r.provider ? `<span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-surface-2 text-text-secondary border border-border">${escapeHtml(r.provider)}</span>` : ""}
          ${r.model ? `<span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-surface-2 text-text-secondary border border-border">${escapeHtml(r.model)}</span>` : ""}
        </div>
        <div class="flex items-center gap-3 text-[11px] font-mono text-text-muted mb-3">
          <span>${prompts} prompts</span>
          <span class="text-border">&middot;</span>
          <span>${tools} tools</span>
          ${duration ? `<span class="text-border">&middot;</span><span>${escapeHtml(duration)}</span>` : ""}
        </div>
        <div class="flex items-center gap-3 text-[11px] font-mono text-text-muted mb-4">
          <span>${escapeHtml(size)}</span>
          <span class="text-border">&middot;</span>
          <span class="inline-flex items-center px-1.5 py-0.5 rounded border text-[10px] ${visibilityColor(vis)}">${visibilityLabel(vis)}</span>
          <span class="text-border">&middot;</span>
          <span>${escapeHtml(expiry)}</span>
          <span class="ml-auto flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            ${views}
          </span>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <a href="/r/${safeId}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-mono rounded-md bg-accent/10 text-accent hover:bg-accent/20 transition-colors">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            View
          </a>
          <button data-copy-link="/r/${safeId}" class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-mono rounded-md bg-surface-2 text-text-secondary hover:text-text-primary hover:bg-surface-2/80 transition-colors cursor-pointer border border-border">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
            Copy link
          </button>
          <select data-visibility-select="${safeId}" class="px-2 py-1.5 text-xs font-mono rounded-md bg-surface-2 text-text-secondary border border-border cursor-pointer appearance-none pr-6 bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2210%22%20height%3D%226%22%20fill%3D%22none%22%3E%3Cpath%20d%3D%22M1%201l4%204%204-4%22%20stroke%3D%22%236b7280%22%20stroke-width%3D%221.5%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%2F%3E%3C%2Fsvg%3E')] bg-no-repeat bg-[right_0.5rem_center]">
            <option value="public" ${vis === "public" ? "selected" : ""}>Public</option>
            <option value="unlisted" ${vis === "unlisted" ? "selected" : ""}>Link only</option>
            <option value="private" ${vis === "private" ? "selected" : ""}>Private</option>
          </select>
          <button data-delete="${safeId}" class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-mono rounded-md text-red-400 hover:bg-red-400/10 transition-colors cursor-pointer border border-transparent hover:border-red-400/20 ml-auto">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            Delete
          </button>
        </div>
      </div>
    `;
  }

  function createGistCard(r: CloudReplay): string {
    const safeGistId = (r.gistId || "").replace(/[^a-f0-9]/g, "");
    const prompts = parseInt(String(r.userPrompts)) || 0;
    const tools = parseInt(String(r.toolCalls)) || 0;
    const views = parseInt(String(r.viewCount)) || 0;
    const duration = formatDuration(r.durationMs);

    return `
      <div class="rounded-xl border border-border bg-surface-1 p-5">
        <div class="flex items-start justify-between mb-2">
          <h3 class="font-mono text-sm font-semibold text-text-primary truncate pr-2">${escapeHtml(r.title)}</h3>
          <span class="text-[10px] text-text-muted shrink-0">${escapeHtml(formatDate(r.createdAt))}</span>
        </div>
        <div class="flex items-center gap-2 mb-3">
          ${r.provider ? `<span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-surface-2 text-text-secondary border border-border">${escapeHtml(r.provider)}</span>` : ""}
          ${r.model ? `<span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-surface-2 text-text-secondary border border-border">${escapeHtml(r.model)}</span>` : ""}
        </div>
        <div class="flex items-center gap-3 text-[11px] font-mono text-text-muted mb-3">
          <span>${prompts} prompts</span>
          <span class="text-border">&middot;</span>
          <span>${tools} tools</span>
          ${duration ? `<span class="text-border">&middot;</span><span>${escapeHtml(duration)}</span>` : ""}
        </div>
        <div class="flex items-center gap-3 text-[11px] font-mono text-text-muted mb-4">
          <span class="inline-flex items-center px-1.5 py-0.5 rounded border text-[10px] text-emerald-400 bg-emerald-400/10 border-emerald-400/20">Public</span>
          <span class="ml-auto flex items-center gap-1">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
            ${views}
          </span>
        </div>
        <div class="flex items-center gap-2 flex-wrap">
          <a href="/view/?gist=${safeGistId}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-mono rounded-md bg-accent/10 text-accent hover:bg-accent/20 transition-colors">
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            View
          </a>
          ${r.gistUrl ? `
          <a href="${escapeHtml(r.gistUrl)}" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-2.5 py-1.5 text-xs font-mono rounded-md bg-surface-2 text-text-secondary hover:text-text-primary hover:bg-surface-2/80 transition-colors border border-border">
            <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            Open on GitHub
          </a>` : ""}
        </div>
      </div>
    `;
  }

  // --- Main logic ---
  async function initProfile() {
    const loading = document.getElementById("loading")!;
    const signedOut = document.getElementById("signed-out")!;
    const profileContent = document.getElementById("profile-content")!;

    // Check auth
    let user: { name?: string; email?: string; image?: string } | null = null;
    try {
      const res = await fetch("/api/auth/get-session", { credentials: "include" });
      const data = await res.json();
      if (data?.session && data?.user) {
        user = data.user;
      }
    } catch {
      // ignore
    }

    loading.classList.add("hidden");

    if (!user) {
      signedOut.classList.remove("hidden");
      return;
    }

    profileContent.classList.remove("hidden");

    // Load replays
    try {
      const res = await fetch("/api/cloud-replays", { credentials: "include" });
      if (!res.ok) throw new Error("Failed to fetch replays");
      const data: ApiResponse = await res.json();

      // Storage
      const usedMb = (data.storage.used / (1024 * 1024)).toFixed(1);
      const limitMb = (data.storage.limit / (1024 * 1024)).toFixed(1);
      const pct = data.storage.limit > 0 ? Math.min(100, (data.storage.used / data.storage.limit) * 100) : 0;
      document.getElementById("storage-text")!.textContent = `${usedMb} MB / ${limitMb} MB used`;
      (document.getElementById("storage-bar") as HTMLElement).style.width = `${pct}%`;
      if (pct > 80) {
        document.getElementById("storage-bar")!.classList.remove("bg-accent");
        document.getElementById("storage-bar")!.classList.add("bg-amber-400");
      }
      if (pct > 95) {
        document.getElementById("storage-bar")!.classList.remove("bg-amber-400");
        document.getElementById("storage-bar")!.classList.add("bg-red-400");
      }

      // Split by storage type
      const cloudReplays = data.replays.filter((r) => r.storageType === "r2");
      const gistReplays = data.replays.filter((r) => r.storageType === "gist");

      // Cloud replays
      const cloudGrid = document.getElementById("cloud-grid")!;
      const cloudEmpty = document.getElementById("cloud-empty")!;
      document.getElementById("cloud-count")!.textContent = String(cloudReplays.length);
      if (cloudReplays.length === 0) {
        cloudEmpty.classList.remove("hidden");
      } else {
        cloudGrid.innerHTML = cloudReplays.map(createCloudCard).join("");
        cloudGrid.classList.remove("hidden");
      }

      // Gist replays
      const gistGrid = document.getElementById("gist-grid")!;
      const gistEmpty = document.getElementById("gist-empty")!;
      document.getElementById("gist-count")!.textContent = String(gistReplays.length);
      if (gistReplays.length === 0) {
        gistEmpty.classList.remove("hidden");
      } else {
        gistGrid.innerHTML = gistReplays.map(createGistCard).join("");
        gistGrid.classList.remove("hidden");
      }

      // --- Event handlers ---

      // Copy link buttons
      cloudGrid.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-copy-link]");
        if (!btn) return;
        const path = btn.dataset.copyLink!;
        const url = `${window.location.origin}${path}`;
        navigator.clipboard.writeText(url).then(() => {
          const original = btn.innerHTML;
          btn.innerHTML = `<svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg> Copied!`;
          setTimeout(() => { btn.innerHTML = original; }, 1500);
        });
      });

      // Visibility select
      cloudGrid.addEventListener("change", async (e) => {
        const select = e.target as HTMLSelectElement;
        const id = select.dataset.visibilitySelect;
        if (!id) return;
        try {
          const res = await fetch(`/api/cloud-replays/${id}`, {
            method: "PATCH",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({ visibility: select.value }),
          });
          if (!res.ok) throw new Error("Failed to update");
          // Update the pill in the same card
          const card = select.closest("[data-replay-id]");
          if (card) {
            const pill = card.querySelector("[class*='text-emerald-400'], [class*='text-amber-400'], [class*='text-red-400']") as HTMLElement | null;
            if (pill) {
              pill.className = `inline-flex items-center px-1.5 py-0.5 rounded border text-[10px] ${visibilityColor(select.value)}`;
              pill.textContent = visibilityLabel(select.value);
            }
          }
        } catch {
          alert("Failed to update visibility");
          // revert — reload is simplest
          window.location.reload();
        }
      });

      // Delete buttons
      cloudGrid.addEventListener("click", async (e) => {
        const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-delete]");
        if (!btn) return;
        const id = btn.dataset.delete!;
        if (!window.confirm("Are you sure you want to delete this replay? This cannot be undone.")) return;

        btn.textContent = "Deleting...";
        btn.classList.add("opacity-50", "pointer-events-none");
        try {
          const res = await fetch(`/api/cloud-replays/${id}`, {
            method: "DELETE",
            credentials: "include",
          });
          if (!res.ok) throw new Error("Failed to delete");
          const card = btn.closest("[data-replay-id]");
          if (card) {
            card.remove();
            // Update count
            const remaining = cloudGrid.querySelectorAll("[data-replay-id]").length;
            document.getElementById("cloud-count")!.textContent = String(remaining);
            if (remaining === 0) {
              cloudGrid.classList.add("hidden");
              cloudEmpty.classList.remove("hidden");
            }
          }
          // Refresh storage — simplest to reload
          window.location.reload();
        } catch {
          alert("Failed to delete replay");
          btn.textContent = "Delete";
          btn.classList.remove("opacity-50", "pointer-events-none");
        }
      });
    } catch {
      profileContent.innerHTML = `
        <div class="rounded-xl border border-border bg-surface-1 p-10 text-center">
          <div class="text-3xl mb-3">&#9888;</div>
          <p class="text-text-muted text-sm">Failed to load replays. Please try again later.</p>
        </div>
      `;
    }
  }

  // --- Auth UI (same as explore.astro) ---
  (async () => {
    const container = document.getElementById("auth-container");
    const loginBtn = document.getElementById("auth-login");
    const userDiv = document.getElementById("auth-user");
    const avatarBtn = document.getElementById("auth-avatar-btn");
    const avatar = document.getElementById("auth-avatar") as HTMLImageElement | null;
    const dropdown = document.getElementById("auth-dropdown");
    const username = document.getElementById("auth-username");
    const logoutBtn = document.getElementById("auth-logout");
    if (!container || !loginBtn || !userDiv || !avatarBtn || !avatar || !dropdown || !username || !logoutBtn) return;

    const show = (el: HTMLElement) => { el.style.display = ""; };

    try {
      const res = await fetch("/api/auth/get-session", { credentials: "include" });
      const data = await res.json();
      show(container);

      if (data?.session && data?.user) {
        avatar.src = data.user.image || "";
        avatar.alt = data.user.name || "";
        username.textContent = data.user.name || data.user.email || "";
        show(userDiv);
      } else {
        show(loginBtn);
      }
    } catch {
      show(container);
      show(loginBtn);
    }

    avatarBtn.addEventListener("click", (e) => {
      e.stopPropagation();
      dropdown.classList.toggle("hidden");
    });

    document.addEventListener("click", () => {
      dropdown.classList.add("hidden");
    });

    const doSignIn = async () => {
      const res = await fetch("/api/auth/sign-in/social", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        credentials: "include",
        body: JSON.stringify({ provider: "github", callbackURL: window.location.pathname }),
      });
      const data = await res.json();
      if (data?.url) window.location.href = data.url;
    };

    loginBtn.addEventListener("click", doSignIn);

    // Sign-in button in the centered card
    const signinBtn = document.getElementById("signin-btn");
    if (signinBtn) signinBtn.addEventListener("click", doSignIn);

    logoutBtn.addEventListener("click", async () => {
      try {
        const res = await fetch("/api/auth/sign-out", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          credentials: "include",
          body: "{}",
        });
        if (!res.ok) console.error("Sign-out failed:", res.status);
      } catch (err) {
        console.error("Sign-out error:", err);
      }
      window.location.reload();
    });
  })();

  // Init profile content
  initProfile();
</script>
