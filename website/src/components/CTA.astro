    <div class="relative inline-flex items-center gap-3 px-8 py-4 bg-surface-1 border border-border rounded-xl font-mono text-lg">
      <span class="text-text-muted select-none">$</span>
      <span class="text-text-primary">npx vibe-replay</span>
    </div>
  </div>
