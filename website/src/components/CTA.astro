---
---

<section class="relative py-32 px-6">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>

  <div class="max-w-3xl mx-auto text-center">
    <!-- Glow -->
    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-accent/8 rounded-full blur-[100px] pointer-events-none"></div>

    <h2 class="relative text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-6">
      Ready to replay?
    </h2>
    <p class="relative text-text-secondary text-lg mb-10 max-w-xl mx-auto">
      Install in seconds. No account needed. No config. Just run the command and share your session.
    </p>

    <div class="relative inline-block group">
      <div class="absolute -inset-0.5 bg-gradient-to-r from-accent/50 to-cyan-400/50 rounded-xl blur opacity-40 group-hover:opacity-60 transition"></div>
      <button
        id="cta-copy-btn"
        class="relative inline-flex items-center gap-3 px-8 py-4 bg-surface-1 border border-border rounded-xl font-mono text-lg hover:border-accent/50 transition-all cursor-pointer"
      >
        <span class="text-text-muted select-none">$</span>
        <span class="text-text-primary">npx vibe-replay</span>
        <svg id="cta-copy-icon" class="w-5 h-5 text-text-muted hover:text-accent transition-colors ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/>
          <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/>
        </svg>
        <svg id="cta-check-icon" class="w-5 h-5 text-accent ml-2 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <polyline points="20 6 9 17 4 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<script>
  document.getElementById("cta-copy-btn")?.addEventListener("click", (e) => {
    e.preventDefault();
    navigator.clipboard.writeText("npx vibe-replay").then(() => {
      const copyIcon = document.getElementById("cta-copy-icon");
      const checkIcon = document.getElementById("cta-check-icon");
      if (copyIcon && checkIcon) {
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");
        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 2000);
      }
    }).catch(() => {});
  });
</script>
