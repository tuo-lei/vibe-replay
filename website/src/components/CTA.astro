    <div class="absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-accent/5 rounded-full blur-[100px] pointer-events-none"></div>

    <h2 class="relative text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight mb-6">
