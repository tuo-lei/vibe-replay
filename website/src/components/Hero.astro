---
import Nav from "./Nav.astro";

const DEMO_URL = "/view/?gist=c40137e4c224dc883fe2eaa668e2d8ba";

const slides = [
  { src: "/screenshots/dashboard.png", label: "Browse all sessions", alt: "Dashboard — activity heatmap, project analytics, session overview" },
  { src: "/screenshots/sessions.png", label: "Browse sessions", alt: "Sessions list — all sessions with prompts, tools, cost, and project grouping" },
  { src: "/screenshots/session-landing.png", label: "Open a session", alt: "Session landing — stats overview with duration, cost, and replay controls" },
  { src: "/screenshots/tool-calls.png", label: "Watch the replay", alt: "Replay viewer — syntax-highlighted diffs, tool calls, and thinking blocks" },
  { src: "/screenshots/insights.png", label: "Analyze with insights", alt: "Session insights — token burn, cache hit rates, tool call breakdown" },
];
---

<Nav />

<section class="relative md:min-h-[90vh] flex flex-col items-center md:justify-center px-4 sm:px-6 pt-14 sm:pt-20 md:pt-24 pb-8 sm:pb-16 overflow-hidden">
  <!-- Animated background -->
  <div class="absolute inset-0 bg-[url('data:image/svg+xml,%3Csvg%20width%3D%2240%22%20height%3D%2240%22%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%3E%3Cpath%20d%3D%22M0%2040L40%200M-10%2010L10-10M30%2050L50%2030%22%20stroke%3D%22%23ffffff%22%20stroke-width%3D%220.5%22/%3E%3C/svg%3E')] opacity-[0.03] pointer-events-none"></div>
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_50%_at_50%_40%,rgba(0,229,160,0.08),transparent_70%)] pointer-events-none"></div>

  <!-- Headline -->
  <div class="relative text-center max-w-4xl mx-auto mb-6 sm:mb-8 md:mb-14">
    <h1 class="text-4xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-[1.1]">
      <span class="bg-gradient-to-r from-accent via-emerald-400 to-cyan-400 bg-clip-text text-transparent">vibe-replay</span>
    </h1>
    <p class="mt-3 sm:mt-5 text-lg sm:text-2xl md:text-3xl text-text-secondary font-medium leading-relaxed">
      <span id="hero-word" class="inline-block text-text-primary font-semibold transition-all duration-300">Replay</span>
      your AI coding sessions
    </p>
  </div>

  <!-- Demo area: terminal → screenshot carousel -->
  <div class="relative w-full max-w-5xl mx-auto">
    <!-- Glow -->
    <div class="absolute -inset-4 bg-gradient-to-r from-accent/10 via-emerald-400/5 to-cyan-400/10 rounded-2xl blur-2xl opacity-60 pointer-events-none"></div>

    <div class="relative rounded-xl border border-border/50 overflow-hidden shadow-2xl shadow-accent/5 bg-[#0d1117]">
      <!-- Browser chrome -->
      <div class="flex items-center gap-3 px-4 py-2.5 bg-[#161b22] border-b border-[#30363d]">
        <div class="flex gap-1.5">
          <div class="w-3 h-3 rounded-full bg-[#ff5f57]/80"></div>
          <div class="w-3 h-3 rounded-full bg-[#febc2e]/80"></div>
          <div class="w-3 h-3 rounded-full bg-[#28c840]/80"></div>
        </div>
        <div class="flex-1 flex justify-center">
          <div id="hero-url-bar" class="px-4 py-1 rounded-md bg-[#0d1117]/60 text-xs text-[#8b949e] font-mono transition-all duration-500">Terminal</div>
        </div>
        <div class="w-[54px]"></div>
      </div>

      <!-- Content area -->
      <div class="relative" style="aspect-ratio: 16/9;">

        <!-- Phase 1: Terminal -->
        <div id="hero-terminal" class="absolute inset-0 flex flex-col p-4 sm:p-6 font-mono text-sm sm:text-base transition-opacity duration-700" style="opacity: 1;">
          <div class="flex-1 flex flex-col justify-center max-w-2xl">
            <div class="flex items-center gap-2 text-[#e6edf3]">
              <span class="text-[#3fb950]">$</span>
              <span id="hero-typed" class=""></span>
              <span id="hero-cursor" class="inline-block w-[8px] h-[18px] bg-[#e6edf3] animate-blink"></span>
            </div>
            <div id="hero-output" class="mt-4 space-y-1 text-xs sm:text-sm hidden">
              <div class="text-[#8b949e]">Discovering sessions...</div>
              <div class="text-[#8b949e]">Found <span class="text-[#3fb950]">152 sessions</span> across <span class="text-[#58a6ff]">26 projects</span></div>
              <div class="text-[#8b949e] mt-1">Generated replay &mdash; <span class="text-[#e6edf3]">512 scenes</span>, <span class="text-[#e6edf3]">537KB</span></div>
              <div class="mt-1 text-[#3fb950]">Opening editor at <span class="underline">http://localhost:13456</span></div>
            </div>
          </div>
        </div>

        <!-- Phase 2: Screenshot carousel -->
        {slides.map((slide, i) => (
          <img
            src={slide.src}
            alt={slide.alt}
            class="hero-slide absolute inset-0 w-full h-full object-cover object-top transition-opacity duration-700"
            style="opacity: 0;"
            data-index={i}
            loading="eager"
          />
        ))}
      </div>

      <!-- Bottom status bar: slide label + dots -->
      <div class="flex items-center justify-between px-4 py-2 bg-[#161b22] border-t border-[#30363d]">
        <span id="hero-slide-label" class="text-xs text-[#8b949e] font-mono transition-opacity duration-300">$ npx vibe-replay</span>
        <div class="flex items-center gap-1.5">
          {slides.map((_, i) => (
            <button
              class="hero-dot w-2 h-2 rounded-full bg-[#30363d] transition-all duration-300 cursor-pointer hover:bg-[#8b949e]"
              data-index={i}
              aria-label={`Go to slide ${i + 1}`}
            />
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- CTAs -->
  <div class="relative mt-6 sm:mt-10 flex flex-col sm:flex-row items-center gap-3 sm:gap-4">
    <a
      href={DEMO_URL}
      class="flex items-center gap-2 px-6 py-3 rounded-lg bg-accent/10 text-accent font-semibold hover:bg-accent/20 transition-colors"
    >
      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
      Watch a real session
    </a>
    <div class="group relative">
      <div class="absolute -inset-0.5 bg-gradient-to-r from-accent/40 to-cyan-400/40 rounded-lg blur opacity-30 group-hover:opacity-50 transition"></div>
      <button
        id="hero-copy-btn"
        class="relative flex items-center gap-3 px-6 py-3 bg-surface-1 border border-border rounded-lg font-mono text-base hover:border-accent/40 transition-all cursor-pointer"
      >
        <span class="text-text-muted select-none">$</span>
        <span class="text-text-primary">npx vibe-replay</span>
        <svg id="hero-copy-icon" class="w-4 h-4 text-text-muted group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/>
          <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/>
        </svg>
        <svg id="hero-check-icon" class="w-4 h-4 text-accent hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <polyline points="20 6 9 17 4 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
  .animate-blink { animation: blink 1s step-end infinite; }
</style>

<script>
  const LABELS = [
    "Browse all sessions",
    "Browse sessions",
    "Open a session",
    "Watch the replay",
    "Analyze with insights",
  ];

  const terminal = document.getElementById("hero-terminal");
  const typed = document.getElementById("hero-typed");
  const cursor = document.getElementById("hero-cursor");
  const output = document.getElementById("hero-output");
  const urlBar = document.getElementById("hero-url-bar");
  const label = document.getElementById("hero-slide-label");
  const slides = document.querySelectorAll<HTMLImageElement>(".hero-slide");
  const dots = document.querySelectorAll<HTMLButtonElement>(".hero-dot");

  let currentSlide = -1; // -1 = terminal phase
  let autoTimer: ReturnType<typeof setTimeout> | null = null;
  let aborted = false;

  // Reduced motion check
  const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  function showSlide(index: number) {
    currentSlide = index;

    // Hide terminal
    if (terminal) terminal.style.opacity = "0";

    // Show correct slide, hide others
    slides.forEach((s, i) => {
      (s as HTMLElement).style.opacity = i === index ? "1" : "0";
    });

    // Update dots
    dots.forEach((d, i) => {
      d.classList.toggle("bg-[#3fb950]", i === index);
      d.classList.toggle("bg-[#30363d]", i !== index);
    });

    // Update label and URL bar
    if (label) {
      label.style.opacity = "0";
      setTimeout(() => {
        label.textContent = LABELS[index];
        label.style.opacity = "1";
      }, 200);
    }
    if (urlBar) urlBar.textContent = "localhost:13456";
  }

  function nextSlide() {
    const next = currentSlide < 0 ? 0 : (currentSlide + 1) % slides.length;
    showSlide(next);
  }

  function startAutoplay() {
    if (autoTimer) clearInterval(autoTimer);
    autoTimer = setInterval(nextSlide, 3500);
  }

  // Dot click handlers
  dots.forEach((dot) => {
    dot.addEventListener("click", () => {
      const idx = Number(dot.dataset.index);
      showSlide(idx);
      startAutoplay(); // restart timer
    });
  });

  // Typing animation
  async function typeText(text: string) {
    if (!typed) return;
    for (let i = 0; i < text.length; i++) {
      if (aborted) return;
      typed.textContent = text.slice(0, i + 1);
      await new Promise((r) => setTimeout(r, 60 + Math.random() * 40));
    }
  }

  async function runDemo() {
    if (prefersReduced) {
      // Skip animation, jump to carousel
      if (cursor) cursor.style.display = "none";
      showSlide(0);
      startAutoplay();
      return;
    }

    // Phase 1: type command
    await typeText("npx vibe-replay");
    await new Promise((r) => setTimeout(r, 400));
    if (aborted) return;

    // Show output
    if (cursor) cursor.style.display = "none";
    if (output) output.classList.remove("hidden");
    await new Promise((r) => setTimeout(r, 2000));
    if (aborted) return;

    // Phase 2: transition to screenshots
    showSlide(0);
    startAutoplay();
  }

  runDemo();

  // Rotating words
  const words = ["Replay", "Analyze", "Share", "Export"];
  const wordEl = document.getElementById("hero-word");
  if (wordEl) {
    let i = 0;
    setInterval(() => {
      i = (i + 1) % words.length;
      wordEl.style.opacity = "0";
      wordEl.style.transform = "translateY(8px)";
      setTimeout(() => {
        wordEl.textContent = words[i];
        wordEl.style.opacity = "1";
        wordEl.style.transform = "translateY(0)";
      }, 200);
    }, 2500);
  }

  // Copy button
  document.getElementById("hero-copy-btn")?.addEventListener("click", () => {
    navigator.clipboard.writeText("npx vibe-replay").then(() => {
      const copyIcon = document.getElementById("hero-copy-icon");
      const checkIcon = document.getElementById("hero-check-icon");
      if (copyIcon && checkIcon) {
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");
        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 2000);
      }
    });
  });
</script>
