---
const DEMO_URL = "/view/?gist=c40137e4c224dc883fe2eaa668e2d8ba";
---

<!-- Top nav -->
<nav class="relative z-20 border-b border-border/50 px-6 py-3">
  <div class="max-w-6xl mx-auto flex items-center justify-between">
    <div class="flex items-center gap-4">
      <a href="/" class="font-mono font-bold text-sm hover:opacity-80 transition-opacity bg-gradient-to-r from-accent via-emerald-400 to-cyan-400 bg-clip-text text-transparent">vibe-replay</a>
      <span class="text-border hidden sm:inline">|</span>
      <a href="/explore" class="text-text-muted hover:text-text-primary text-sm transition-colors hidden sm:inline">Explore</a>
    </div>
    <div class="flex items-center gap-4">
      <a class="github-button" href="https://github.com/tuo-lei/vibe-replay" data-color-scheme="dark" data-icon="octicon-star" data-size="large" data-show-count="true" aria-label="Star tuo-lei/vibe-replay on GitHub">Star</a>
      <a href="https://www.npmjs.com/package/vibe-replay" target="_blank" rel="noopener" class="text-text-muted hover:text-text-primary transition-colors" title="npm">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M0 7.334v8h6.666v1.332H12v-1.332h12v-8H0zm6.666 6.664H5.334v-4H3.999v4H1.335V8.667h5.331v5.331zm4 0v1.336H8.001V8.667h5.334v5.332h-2.669v-.001zm12.001 0h-1.33v-4h-1.336v4h-1.335v-4h-1.33v4h-2.671V8.667h8.002v5.331zM10.665 10H12v2.667h-1.335V10z"/></svg>
      </a>
    </div>
  </div>
</nav>

<section class="relative overflow-hidden pt-16 pb-8">
  <!-- Grid background -->
  <div class="absolute inset-0 bg-[linear-gradient(rgba(42,42,62,0.3)_1px,transparent_1px),linear-gradient(90deg,rgba(42,42,62,0.3)_1px,transparent_1px)] bg-[size:64px_64px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_40%,black_20%,transparent_100%)]"></div>

  <!-- Glow orb -->
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
    <!-- Badge -->
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-border bg-surface-1/80 backdrop-blur-sm text-sm text-text-secondary mb-8 animate-fade-in">
      <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
      Open Source &middot; MIT License
    </div>

    <!-- Headline -->
    <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-extrabold tracking-tight leading-[1.05] mb-6 animate-slide-up">
      <span class="bg-gradient-to-r from-accent via-emerald-400 to-cyan-400 bg-clip-text text-transparent">
        vibe-replay
      </span>
      <br />
      <span class="text-text-primary text-4xl sm:text-5xl md:text-6xl lg:text-7xl">
        Replay your AI coding sessions
      </span>
    </h1>

    <!-- Subheadline -->
    <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-10 animate-slide-up" style="animation-delay: 0.1s">
      Turn your Claude Code and Cursor sessions into interactive, shareable web replays &mdash; as single, self-contained HTML files.
    </p>

    <!-- Install command -->
    <div class="flex items-center justify-center mb-14 animate-slide-up" style="animation-delay: 0.2s">
      <div class="group relative">
        <div class="absolute -inset-0.5 bg-gradient-to-r from-accent/50 to-cyan-400/50 rounded-lg blur opacity-40 group-hover:opacity-60 transition"></div>
        <button
          id="copy-btn"
          class="relative flex items-center gap-3 px-6 py-3.5 bg-surface-1 border border-border rounded-lg font-mono text-base hover:border-accent/50 transition-all cursor-pointer"
        >
          <span class="text-text-muted select-none">$</span>
          <span class="text-text-primary">npx vibe-replay</span>
          <svg id="copy-icon" class="w-4 h-4 text-text-muted hover:text-accent transition-colors ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/>
          </svg>
          <svg id="check-icon" class="w-4 h-4 text-accent ml-2 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <polyline points="20 6 9 17 4 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Product mockup with hover overlay -->
    <a href={DEMO_URL} class="block max-w-5xl mx-auto animate-slide-up group relative" style="animation-delay: 0.3s">
      <!-- Hover overlay: "See it live" -->
      <div class="absolute inset-0 z-10 rounded-xl bg-black/60 backdrop-blur-sm opacity-0 group-hover:opacity-100 transition-all duration-300 flex items-center justify-center">
        <div class="flex flex-col items-center gap-3">
          <div class="w-16 h-16 rounded-full bg-accent/20 border-2 border-accent flex items-center justify-center">
            <svg class="w-7 h-7 text-accent ml-1" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
          </div>
          <span class="text-white font-mono text-lg font-semibold">See it live</span>
          <span class="text-white/60 text-sm">A real vibe-replay session</span>
        </div>
      </div>

      <div class="rounded-xl border border-border group-hover:border-accent/40 bg-[#0d1117] shadow-2xl shadow-black/60 overflow-hidden transition-all duration-300">
        <!-- Viewer header bar -->
        <div class="flex items-center justify-between px-4 py-2.5 border-b border-[#30363d] bg-[#161b22] text-xs font-mono">
          <div class="flex items-center gap-3">
            <span class="text-[#3fb950] font-semibold">vibe-replay</span>
            <span class="text-[#e6edf3] hidden sm:inline">Annotations, editor mode, token tracking</span>
            <span class="text-[#8b949e] hidden sm:inline">&middot;</span>
            <span class="text-[#e6edf3]/60 hidden sm:inline">claude-opus-4-20250514 &middot; 1h 24m</span>
          </div>
          <div class="hidden sm:flex items-center gap-3 text-[#8b949e]">
            <span class="px-1.5 py-0.5 rounded bg-[#3fb950]/15 text-[#3fb950]">All</span>
            <span class="px-1.5 py-0.5 rounded bg-[#1a1a24] text-[#8b949e]">Prompts</span>
            <!-- Settings gear -->
            <svg class="w-3.5 h-3.5 text-[#8b949e]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
          </div>
        </div>

        <!-- Main area: sidebar + content + comments -->
        <div class="flex" style="height: 460px;">
          <!-- Sidebar minimap -->
          <div class="hidden md:block w-44 border-r border-[#30363d] bg-[#0d1117] p-3 overflow-hidden">
            <div class="flex items-center gap-2 mb-2">
              <div class="text-[10px] font-mono text-[#3fb950] uppercase tracking-wider border-b border-[#3fb950] pb-1">Outline</div>
              <div class="text-[10px] font-mono text-[#8b949e] uppercase tracking-wider pb-1">Stats</div>
            </div>
            <!-- Turn entries -->
            <div class="space-y-2">
              <!-- Turn 1 -->
              <div class="rounded px-2 py-1.5 bg-[#3fb950]/5 border-l-2 border-[#3fb950]">
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] font-mono text-[#3fb950] font-bold">01</span>
                  <span class="text-[10px] text-[#e6edf3] truncate">Implement annotations...</span>
                </div>
                <div class="flex gap-1 mt-1">
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#d29922]/15 text-[#d29922]">42 tools</span>
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#58a6ff]/15 text-[#58a6ff]">8 resp</span>
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#bc8cff]/15 text-[#bc8cff]">think</span>
                </div>
              </div>
              <!-- Turn 2 -->
              <div class="rounded px-2 py-1.5 opacity-70">
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] font-mono text-[#8b949e]">02</span>
                  <span class="text-[10px] text-[#8b949e] truncate">Fix the editor mode...</span>
                </div>
                <div class="flex gap-1 mt-1">
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#d29922]/15 text-[#d29922]">18 tools</span>
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#58a6ff]/15 text-[#58a6ff]">5 resp</span>
                </div>
              </div>
              <!-- Compaction marker -->
              <div class="rounded px-2 py-1.5 border border-dashed border-[#30363d] opacity-60">
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] text-[#8b949e]">&#8635;</span>
                  <span class="text-[9px] text-[#8b949e] italic">Context compacted</span>
                </div>
              </div>
              <!-- Turn 3 -->
              <div class="rounded px-2 py-1.5 opacity-70">
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] font-mono text-[#8b949e]">03</span>
                  <span class="text-[10px] text-[#8b949e] truncate">Add token tracking...</span>
                </div>
                <div class="flex gap-1 mt-1">
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#d29922]/15 text-[#d29922]">35 tools</span>
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#58a6ff]/15 text-[#58a6ff]">6 resp</span>
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#bc8cff]/15 text-[#bc8cff]">think</span>
                </div>
              </div>
              <!-- Turn 4 -->
              <div class="rounded px-2 py-1.5 opacity-70">
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] font-mono text-[#8b949e]">04</span>
                  <span class="text-[10px] text-[#8b949e] truncate">Compaction summaries...</span>
                </div>
                <div class="flex gap-1 mt-1">
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#d29922]/15 text-[#d29922]">28 tools</span>
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#58a6ff]/15 text-[#58a6ff]">4 resp</span>
                </div>
              </div>
              <!-- Turn 5 -->
              <div class="rounded px-2 py-1.5 opacity-70">
                <div class="flex items-center gap-1.5">
                  <span class="text-[10px] font-mono text-[#8b949e]">05</span>
                  <span class="text-[10px] text-[#8b949e] truncate">Fix viewer mode enum...</span>
                </div>
                <div class="flex gap-1 mt-1">
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#d29922]/15 text-[#d29922]">12 tools</span>
                  <span class="text-[8px] px-1 py-0.5 rounded bg-[#58a6ff]/15 text-[#58a6ff]">3 resp</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Content area -->
          <div class="flex-1 overflow-hidden p-4 sm:p-6 space-y-4 font-mono text-sm text-left">
            <!-- User prompt with comment badge -->
            <div class="rounded-lg bg-[#3fb950]/5 border border-[#3fb950]/15 p-4 relative">
              <!-- Comment badge -->
              <div class="absolute -top-1.5 -right-1.5 w-5 h-5 rounded-full bg-[#58a6ff] text-white text-[9px] font-bold flex items-center justify-center shadow-sm">2</div>
              <div class="flex items-center gap-2 mb-2">
                <span class="text-[10px] font-bold uppercase tracking-wider text-[#3fb950]">You</span>
                <span class="text-[10px] text-[#8b949e]">10:21 PM</span>
              </div>
              <p class="text-[#3fb950]/90 text-sm leading-relaxed">Implement annotations system — users should be able to add comments to any scene, with a comments panel, persistence, and export support.</p>
            </div>

            <!-- Thinking block -->
            <div class="rounded-lg bg-[#bc8cff]/[0.03] border border-[#bc8cff]/10 p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-[10px] font-bold uppercase tracking-wider text-[#bc8cff]/60">Thinking</span>
              </div>
              <p class="text-[#8b949e] text-xs leading-relaxed">I need to design an annotation system that works across all three viewer modes: embedded HTML, editor mode with local server, and readonly gist/URL viewing. Let me plan the data model first...</p>
            </div>

            <!-- Tool call: Write file -->
            <div class="rounded-lg bg-[#d29922]/[0.03] border border-[#d29922]/10 p-4">
              <div class="flex items-center gap-2">
                <svg class="w-3.5 h-3.5 text-[#d29922]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider text-[#d29922]">Write</span>
                <span class="text-[#8b949e] text-xs">packages/viewer/src/AnnotationPanel.tsx</span>
              </div>
            </div>

            <!-- Tool call: Edit file with diff -->
            <div class="rounded-lg bg-[#d29922]/[0.03] border border-[#d29922]/10 p-4 relative">
              <!-- Comment badge on tool call -->
              <div class="absolute -top-1.5 -right-1.5 w-5 h-5 rounded-full bg-[#58a6ff] text-white text-[9px] font-bold flex items-center justify-center shadow-sm">1</div>
              <div class="flex items-center gap-2 mb-3">
                <svg class="w-3.5 h-3.5 text-[#d29922]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" /></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider text-[#d29922]">Edit</span>
                <span class="text-[#8b949e] text-xs">packages/cli/src/types.ts</span>
              </div>
              <!-- Mini diff -->
              <div class="rounded bg-[#0d1117] border border-[#30363d] text-xs overflow-hidden">
                <div class="px-3 py-1 bg-[#3fb950]/10 text-[#3fb950]">
                  <span class="select-none text-[#3fb950]/40">+ </span>annotations?: Annotation[];
                </div>
                <div class="px-3 py-1 bg-[#3fb950]/10 text-[#3fb950]">
                  <span class="select-none text-[#3fb950]/40">+ </span>interface Annotation &#123;
                </div>
                <div class="px-3 py-1 bg-[#3fb950]/10 text-[#3fb950]">
                  <span class="select-none text-[#3fb950]/40">+ </span>&nbsp; id: string; sceneIndex: number;
                </div>
              </div>
            </div>

            <!-- Bash command -->
            <div class="rounded-lg bg-[#d29922]/[0.03] border border-[#d29922]/10 p-4">
              <div class="flex items-center gap-2 mb-2">
                <svg class="w-3.5 h-3.5 text-[#d29922]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z" /></svg>
                <span class="text-[10px] font-bold uppercase tracking-wider text-[#d29922]">Bash</span>
                <span class="text-[#8b949e] text-xs">pnpm build</span>
              </div>
              <div class="rounded bg-[#0d1117] border border-[#30363d] text-xs p-2 text-[#8b949e]">
                <div>✓ viewer: 435.85 kB &middot; built in 665ms</div>
              </div>
            </div>
          </div>

          <!-- Comments sidebar (desktop only) -->
          <div class="hidden lg:block w-52 border-l border-[#30363d] bg-[#0d1117] p-3 overflow-hidden">
            <div class="flex items-center justify-between mb-3">
              <span class="text-[10px] font-mono text-[#e6edf3] uppercase tracking-wider font-semibold">Comments <span class="text-[#8b949e]">(3)</span></span>
            </div>
            <!-- Comment 1 -->
            <div class="rounded-lg bg-[#161b22] border border-[#30363d] p-2.5 mb-2">
              <div class="text-[9px] text-[#58a6ff] mb-1 truncate">You &mdash; Implement annotations...</div>
              <p class="text-[10px] text-[#e6edf3]/80 leading-relaxed mb-1.5">Great starting prompt. The three-mode architecture was the key insight here.</p>
              <div class="text-[8px] text-[#8b949e]">Mar 5, 2026</div>
            </div>
            <!-- Comment 2 -->
            <div class="rounded-lg bg-[#161b22] border border-[#30363d] p-2.5 mb-2">
              <div class="text-[9px] text-[#58a6ff] mb-1 truncate">You &mdash; Implement annotations...</div>
              <p class="text-[10px] text-[#e6edf3]/80 leading-relaxed mb-1.5">Notice how it planned the Hono server routes before touching the viewer.</p>
              <div class="text-[8px] text-[#8b949e]">Mar 5, 2026</div>
            </div>
            <!-- Comment 3 -->
            <div class="rounded-lg bg-[#161b22] border border-[#30363d] p-2.5">
              <div class="text-[9px] text-[#d29922] mb-1 truncate">Edit &mdash; types.ts</div>
              <p class="text-[10px] text-[#e6edf3]/80 leading-relaxed mb-1.5">The annotation type design is clean &mdash; `sceneIndex` makes lookup O(1).</p>
              <div class="text-[8px] text-[#8b949e]">Mar 5, 2026</div>
            </div>
          </div>
        </div>

        <!-- Playback controls bar -->
        <div class="border-t border-[#30363d] bg-[#161b22]/90">
          <!-- Timeline with annotation dots -->
          <div class="relative h-2 px-3 pt-2">
            <!-- Annotation dots -->
            <div class="absolute top-0 left-[8%] w-1.5 h-1.5 rounded-full bg-[#58a6ff]"></div>
            <div class="absolute top-0 left-[35%] w-1.5 h-1.5 rounded-full bg-[#58a6ff]"></div>
            <!-- Timeline segments -->
            <div class="flex gap-[1px] h-full">
              <div class="flex-[3] rounded-sm bg-[#3fb950]/60"></div>
              <div class="flex-[2] rounded-sm bg-[#bc8cff]/40"></div>
              <div class="flex-[5] rounded-sm bg-[#58a6ff]/50"></div>
              <div class="flex-[2] rounded-sm bg-[#d29922]/50"></div>
              <div class="flex-[3] rounded-sm bg-[#d29922]/50"></div>
              <div class="flex-[4] rounded-sm bg-[#58a6ff]/50"></div>
              <div class="flex-[2] rounded-sm bg-[#d29922]/50"></div>
              <div class="flex-[3] rounded-sm bg-[#3fb950]/60 ring-1 ring-white/60"></div>
              <div class="flex-[2] rounded-sm bg-[#bc8cff]/30"></div>
              <div class="flex-[4] rounded-sm bg-[#58a6ff]/30"></div>
              <div class="flex-[2] rounded-sm bg-[#d29922]/30"></div>
              <div class="flex-[3] rounded-sm bg-[#58a6ff]/30"></div>
            </div>
          </div>
          <!-- Controls -->
          <div class="flex items-center justify-between px-4 py-2 text-xs font-mono text-[#8b949e]">
            <div class="flex items-center gap-3">
              <!-- Play button -->
              <div class="w-7 h-7 flex items-center justify-center rounded border border-[#30363d] text-[#e6edf3]">
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
              </div>
              <!-- Speed buttons -->
              <div class="hidden sm:flex items-center gap-1">
                <span class="px-1.5 py-0.5 rounded bg-[#3fb950]/15 text-[#3fb950] text-[10px]">1x</span>
                <span class="px-1.5 py-0.5 rounded text-[#8b949e] text-[10px]">5x</span>
                <span class="px-1.5 py-0.5 rounded text-[#8b949e] text-[10px]">10x</span>
              </div>
              <span class="text-[#8b949e] hidden sm:inline">|</span>
              <!-- Turn nav -->
              <span>&lt; Turn <span class="text-[#e6edf3]">3</span>/9 &gt;</span>
              <span class="text-[#8b949e] hidden sm:inline">|</span>
              <!-- Search -->
              <span class="hidden sm:flex items-center gap-1 text-[#8b949e]">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              </span>
              <!-- Comments toggle -->
              <span class="hidden sm:flex items-center gap-1 px-1.5 py-0.5 rounded bg-[#58a6ff]/15 text-[#58a6ff] text-[10px]">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg>
                3
              </span>
            </div>
            <div class="flex items-center gap-3">
              <span>Scene <span class="text-[#e6edf3]">124</span>/512</span>
              <span class="text-[10px] text-[#8b949e]/50 hidden sm:inline">Space &middot; ←→ &middot; ⌘K</span>
            </div>
          </div>
        </div>
      </div>
    </a>

    <!-- Big CTA below mockup -->
    <div class="mt-10 animate-slide-up" style="animation-delay: 0.5s">
      <a href={DEMO_URL} class="group inline-flex items-center gap-3 px-8 py-4 rounded-xl bg-accent hover:bg-accent-dim text-surface font-semibold text-lg transition-all shadow-lg shadow-accent/20 hover:shadow-accent/30">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg>
        Watch a real session
