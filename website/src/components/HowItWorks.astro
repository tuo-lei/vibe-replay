---
---

<section id="how-it-works" class="relative py-32 px-6">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-20">
      <p class="text-accent/70 font-mono text-sm font-medium tracking-wider uppercase mb-3">How it works</p>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight">
        One command, full context
      </h2>
      <p class="mt-4 text-text-secondary text-lg max-w-2xl mx-auto">PR diffs show <em>what</em> changed. vibe-replay shows <em>why</em> &mdash; every prompt, every thought, every edit, in one shareable file.</p>
    </div>

    <!-- Steps -->
    <div class="space-y-24">

      <!-- Step 1: Dashboard -->
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="md:w-2/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/10 to-cyan-400/5 flex items-center justify-center text-accent font-mono text-sm font-bold">1</span>
            <h3 class="text-xl font-semibold">All your sessions, one place</h3>
          </div>
          <p class="text-text-secondary leading-relaxed">A local dashboard shows every session across <span class="text-[#D97706] font-medium">Claude Code</span> and <span class="text-[#0096FF] font-medium">Cursor</span> — searchable, filterable, organized by project. Runs entirely on your machine. Nothing leaves.</p>
        </div>
        <div class="md:w-3/5 rounded-xl border border-[#30363d] bg-[#0d1117] overflow-hidden font-mono text-xs">
          <!-- Header -->
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-[#30363d] bg-[#161b22]">
            <div class="flex items-center gap-2">
              <span class="text-[#3fb950] font-semibold text-sm">vibe-replay</span>
              <span class="text-[#30363d]">|</span>
              <span class="text-[#8b949e]">Sessions</span>
            </div>
            <div class="flex items-center gap-1.5">
              <div class="px-2.5 py-1 rounded-md text-[11px] bg-[#3fb950]/15 text-[#3fb950] font-semibold">Sessions</div>
              <div class="px-2.5 py-1 rounded-md text-[11px] text-[#8b949e]">Replays</div>
            </div>
          </div>
          <!-- Session cards -->
          <div class="p-3 space-y-2">
            <!-- Claude session (active) -->
            <div class="rounded-xl bg-[#161b22] border border-[#30363d] px-4 py-3 space-y-2">
              <div class="flex items-center justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="text-[#e6edf3] text-sm font-medium truncate">Refactor auth to use JWT tokens</div>
                  <div class="text-[#8b949e] text-[10px] mt-0.5 truncate">slug: refactor-auth-jwt</div>
                </div>
                <button class="h-7 px-3 text-xs font-semibold rounded-md bg-[#3fb950]/15 text-[#3fb950] shrink-0">Open</button>
              </div>
              <div class="flex items-center gap-1.5 flex-wrap">
                <span class="px-1.5 py-0.5 rounded-md bg-[#1a1a24] text-[#8b949e]">9 prompts</span>
                <span class="px-1.5 py-0.5 rounded-md bg-[#d29922]/15 text-[#d29922]">42 tools</span>
                <span class="px-1.5 py-0.5 rounded-md bg-[#3fb950]/10 text-[#3fb950]">$0.38</span>
              </div>
              <div class="flex items-center gap-2 text-[10px] text-[#8b949e]">
                <span class="px-1.5 py-0.5 rounded-full bg-[#d29922]/15 text-[#D97706] font-medium uppercase tracking-wide">Claude</span>
                <span>~/Code/my-app</span>
                <span class="text-[#30363d]">&middot;</span>
                <span>Mar 8, 22:15</span>
              </div>
            </div>
            <!-- Cursor session -->
            <div class="rounded-xl bg-[#161b22] border border-[#30363d] px-4 py-3 space-y-2 opacity-75">
              <div class="flex items-center justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="text-[#e6edf3] text-sm font-medium truncate">Build landing page with Astro</div>
                  <div class="text-[#8b949e] text-[10px] mt-0.5 truncate">slug: landing-page-astro</div>
                </div>
                <button class="h-7 px-3 text-xs rounded-md bg-[#161b22] text-[#8b949e] border border-[#30363d] shrink-0">Open</button>
              </div>
              <div class="flex items-center gap-1.5 flex-wrap">
                <span class="px-1.5 py-0.5 rounded-md bg-[#1a1a24] text-[#8b949e]">6 prompts</span>
                <span class="px-1.5 py-0.5 rounded-md bg-[#d29922]/15 text-[#d29922]">28 tools</span>
                <span class="px-1.5 py-0.5 rounded-md bg-[#3fb950]/10 text-[#3fb950]">$0.21</span>
              </div>
              <div class="flex items-center gap-2 text-[10px] text-[#8b949e]">
                <span class="px-1.5 py-0.5 rounded-full bg-[#0096FF]/15 text-[#0096FF] font-medium uppercase tracking-wide">Cursor</span>
                <span>~/Code/website</span>
                <span class="text-[#30363d]">&middot;</span>
                <span>Mar 7, 14:20</span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Insights + Viewer -->
      <div class="flex flex-col md:flex-row-reverse items-center gap-10">
        <div class="md:w-2/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/10 to-cyan-400/5 flex items-center justify-center text-accent font-mono text-sm font-bold">2</span>
            <h3 class="text-xl font-semibold">Understand what actually happened</h3>
          </div>
          <p class="text-text-secondary leading-relaxed">Auto-generated insights for every session: prompt timeline, files changed, tool breakdown, token usage and costs. Then step through every thinking block, tool call, and diff — not just the final result.</p>
        </div>
        <div class="md:w-3/5 rounded-xl border border-[#30363d] bg-[#0d1117] overflow-hidden font-mono text-xs">
          <!-- Tab bar: Replay / Summary -->
          <div class="flex items-center gap-0 border-b border-[#30363d] bg-[#161b22] text-[11px]">
            <div class="px-4 py-2.5 text-[#8b949e]">Replay</div>
            <div class="px-4 py-2.5 border-b-2 border-[#3fb950] text-[#3fb950] font-semibold bg-[#3fb950]/5">Summary</div>
            <div class="px-4 py-2.5 text-[#8b949e]">Export</div>
          </div>
          <!-- Overview cards grid -->
          <div class="grid grid-cols-4 gap-0 border-b border-[#30363d]">
            <div class="px-3 py-3 text-center border-r border-[#30363d]">
              <div class="text-[#3fb950] text-lg font-bold tabular-nums">9</div>
              <div class="text-[9px] text-[#8b949e] uppercase tracking-wider mt-0.5">Turns</div>
            </div>
            <div class="px-3 py-3 text-center border-r border-[#30363d]">
              <div class="text-[#d29922] text-lg font-bold tabular-nums">408</div>
              <div class="text-[9px] text-[#8b949e] uppercase tracking-wider mt-0.5">Tool Calls</div>
            </div>
            <div class="px-3 py-3 text-center border-r border-[#30363d]">
              <div class="text-[#58a6ff] text-lg font-bold tabular-nums">18</div>
              <div class="text-[9px] text-[#8b949e] uppercase tracking-wider mt-0.5">Files Modified</div>
            </div>
            <div class="px-3 py-3 text-center">
              <div class="text-[#e6edf3] text-lg font-bold tabular-nums">512</div>
              <div class="text-[9px] text-[#8b949e] uppercase tracking-wider mt-0.5">Scenes</div>
            </div>
          </div>
          <!-- Duration + Cost + Model row -->
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-[#30363d] text-[11px]">
            <div class="flex items-center gap-4">
              <div class="flex items-center gap-1.5">
                <span class="text-[#8b949e]">Duration</span>
                <span class="text-[#e6edf3] font-semibold">58m 22s</span>
              </div>
              <div class="flex items-center gap-1.5">
                <span class="text-[#8b949e]">Cost</span>
                <span class="text-[#3fb950] font-semibold">$92.50</span>
              </div>
            </div>
            <div class="text-[#8b949e]">claude-opus-4-6 &middot; claude-code</div>
          </div>
          <!-- Token usage -->
          <div class="px-4 pt-3 pb-2 border-b border-[#30363d]">
            <div class="text-[10px] font-sans font-semibold text-[#8b949e] uppercase tracking-widest mb-2">Token Usage</div>
            <div class="grid grid-cols-2 gap-x-6 gap-y-1">
              <div class="flex justify-between">
                <span class="text-[#8b949e]">Input</span>
                <span class="text-[#e6edf3] tabular-nums">1.2M</span>
              </div>
              <div class="flex justify-between">
                <span class="text-[#8b949e]">Output</span>
                <span class="text-[#e6edf3] tabular-nums">186.4K</span>
              </div>
              <div class="flex justify-between">
                <span class="text-[#8b949e]">Cache read</span>
                <span class="text-[#e6edf3] tabular-nums">980.2K</span>
              </div>
              <div class="flex justify-between">
                <span class="text-[#8b949e]">Cache write</span>
                <span class="text-[#e6edf3] tabular-nums">245.8K</span>
              </div>
            </div>
          </div>
          <!-- Two column: Prompt Timeline + Top Tools -->
          <div class="grid grid-cols-2 gap-0">
            <!-- Prompt timeline -->
            <div class="px-4 pt-3 pb-3 border-r border-[#30363d]">
              <div class="text-[10px] font-sans font-semibold text-[#8b949e] uppercase tracking-widest mb-2">Prompt Timeline</div>
              <div class="space-y-0.5">
                <div class="flex items-center gap-2 py-1 px-1.5 rounded bg-[#161b22]">
                  <span class="text-[#3fb950] w-5 text-right shrink-0 tabular-nums">01</span>
                  <span class="text-[#e6edf3] flex-1 truncate">Implement annotations...</span>
                  <span class="text-[#8b949e] shrink-0">42 tools</span>
                </div>
                <div class="flex items-center gap-2 py-1 px-1.5 rounded opacity-70">
                  <span class="text-[#3fb950] w-5 text-right shrink-0 tabular-nums">02</span>
                  <span class="text-[#e6edf3] flex-1 truncate">Fix editor mode bug...</span>
                  <span class="text-[#8b949e] shrink-0">18 tools</span>
                </div>
                <div class="flex items-center gap-2 py-1 px-1.5 rounded opacity-50">
                  <span class="text-[#3fb950] w-5 text-right shrink-0 tabular-nums">03</span>
                  <span class="text-[#e6edf3] flex-1 truncate">Add token tracking...</span>
                  <span class="text-[#8b949e] shrink-0">35 tools</span>
                </div>
                <div class="flex items-center gap-2 py-1 px-1.5 rounded opacity-40">
                  <span class="text-[#8b949e] w-5 text-right shrink-0 tabular-nums">&hellip;</span>
                  <span class="text-[#8b949e] flex-1">6 more prompts</span>
                </div>
              </div>
            </div>
            <!-- Top tools bar -->
            <div class="px-4 pt-3 pb-3">
              <div class="text-[10px] font-sans font-semibold text-[#8b949e] uppercase tracking-widest mb-2">Top Tools</div>
              <div class="space-y-1.5">
                <div class="flex items-center gap-2">
                  <span class="text-[#e6edf3] w-10 text-right shrink-0 truncate">Edit</span>
                  <div class="flex-1 h-1.5 rounded-full bg-[#161b22] overflow-hidden">
                    <div class="h-full rounded-full bg-[#d29922]" style="width:100%"></div>
                  </div>
                  <span class="text-[#8b949e] w-6 text-right shrink-0">148</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[#e6edf3] w-10 text-right shrink-0 truncate">Read</span>
                  <div class="flex-1 h-1.5 rounded-full bg-[#161b22] overflow-hidden">
                    <div class="h-full rounded-full bg-[#d29922]" style="width:62%"></div>
                  </div>
                  <span class="text-[#8b949e] w-6 text-right shrink-0">92</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[#e6edf3] w-10 text-right shrink-0 truncate">Write</span>
                  <div class="flex-1 h-1.5 rounded-full bg-[#161b22] overflow-hidden">
                    <div class="h-full rounded-full bg-[#d29922]" style="width:45%"></div>
                  </div>
                  <span class="text-[#8b949e] w-6 text-right shrink-0">67</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[#e6edf3] w-10 text-right shrink-0 truncate">Bash</span>
                  <div class="flex-1 h-1.5 rounded-full bg-[#161b22] overflow-hidden">
                    <div class="h-full rounded-full bg-[#d29922]" style="width:28%"></div>
                  </div>
                  <span class="text-[#8b949e] w-6 text-right shrink-0">41</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[#e6edf3] w-10 text-right shrink-0 truncate">Glob</span>
                  <div class="flex-1 h-1.5 rounded-full bg-[#161b22] overflow-hidden">
                    <div class="h-full rounded-full bg-[#d29922]" style="width:20%"></div>
                  </div>
                  <span class="text-[#8b949e] w-6 text-right shrink-0">30</span>
                </div>
                <div class="flex items-center gap-2">
                  <span class="text-[#e6edf3] w-10 text-right shrink-0 truncate">Grep</span>
                  <div class="flex-1 h-1.5 rounded-full bg-[#161b22] overflow-hidden">
                    <div class="h-full rounded-full bg-[#d29922]" style="width:13%"></div>
                  </div>
                  <span class="text-[#8b949e] w-6 text-right shrink-0">20</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Export -->
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="md:w-2/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/10 to-cyan-400/5 flex items-center justify-center text-accent font-mono text-sm font-bold">3</span>
            <h3 class="text-xl font-semibold">Export in any format</h3>
          </div>
          <p class="text-text-secondary leading-relaxed">A self-contained HTML file. An animated SVG to commit to your repo. A structured Markdown summary for PRs and documentation.</p>
        </div>
        <div class="md:w-3/5">
          <img
            src="/session-preview-demo.svg"
            alt="Animated SVG preview of a real vibe-replay session"
            class="w-full rounded-xl border border-border"
          />
        </div>
      </div>

      <!-- Step 4: Share to the world -->
      <div class="flex flex-col md:flex-row-reverse items-center gap-10">
        <div class="md:w-2/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/10 to-cyan-400/5 flex items-center justify-center text-accent font-mono text-sm font-bold">4</span>
            <h3 class="text-xl font-semibold">Share to the world</h3>
          </div>
          <p class="text-text-secondary leading-relaxed">Publish to GitHub Gist with one click. Your replay gets a permanent link on vibe-replay.com &mdash; and shows up on the Explore page for the community.</p>
        </div>
        <div class="md:w-3/5 rounded-xl border border-[#30363d] bg-[#0d1117] overflow-hidden font-mono text-xs">
          <!-- Explore page header -->
          <div class="flex items-center justify-between px-4 py-2.5 border-b border-[#30363d] bg-[#161b22]">
            <div class="flex items-center gap-2">
              <span class="text-[#3fb950] font-semibold text-sm">vibe-replay</span>
              <span class="text-[#30363d]">|</span>
              <span class="text-[#e6edf3] text-[11px]">Explore</span>
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-3.5 h-3.5 text-[#8b949e]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
              <span class="text-[10px] text-[#8b949e]">Search replays...</span>
            </div>
          </div>
          <!-- Replay cards -->
          <div class="p-3 space-y-2">
            <!-- Featured card -->
            <div class="rounded-xl bg-[#161b22] border border-[#3fb950]/30 px-4 py-3 space-y-2">
              <div class="flex items-center justify-between">
                <span class="text-[#e6edf3] text-sm font-medium">Comment feature in Vibe Replay</span>
                <span class="text-[10px] text-[#3fb950] px-1.5 py-0.5 rounded-full bg-[#3fb950]/10">Live</span>
              </div>
              <div class="flex items-center gap-1.5 flex-wrap">
                <span class="px-1.5 py-0.5 rounded-md bg-[#1a1a24] text-[#8b949e]">14 turns</span>
                <span class="px-1.5 py-0.5 rounded-md bg-[#d29922]/15 text-[#d29922]">408 tools</span>
                <span class="px-1.5 py-0.5 rounded-md bg-[#58a6ff]/15 text-[#58a6ff]">18 files</span>
                <span class="px-1.5 py-0.5 rounded-md bg-[#3fb950]/10 text-[#3fb950]">58m</span>
              </div>
              <div class="flex items-center gap-2 text-[10px] text-[#8b949e]">
                <span class="px-1.5 py-0.5 rounded-full bg-[#d29922]/15 text-[#D97706] font-medium uppercase tracking-wide">Claude</span>
                <span>@tuo-lei</span>
                <span class="text-[#30363d]">&middot;</span>
                <span>Mar 8, 2026</span>
              </div>
            </div>
            <!-- Another card -->
            <div class="rounded-xl bg-[#161b22] border border-[#30363d] px-4 py-3 space-y-2 opacity-70">
              <div class="flex items-center justify-between">
                <span class="text-[#e6edf3] text-sm font-medium">Refactor auth to use JWT tokens</span>
                <span class="text-[10px] text-[#3fb950] px-1.5 py-0.5 rounded-full bg-[#3fb950]/10">Live</span>
              </div>
              <div class="flex items-center gap-1.5 flex-wrap">
                <span class="px-1.5 py-0.5 rounded-md bg-[#1a1a24] text-[#8b949e]">9 turns</span>
                <span class="px-1.5 py-0.5 rounded-md bg-[#d29922]/15 text-[#d29922]">42 tools</span>
                <span class="px-1.5 py-0.5 rounded-md bg-[#58a6ff]/15 text-[#58a6ff]">7 files</span>
              </div>
              <div class="flex items-center gap-2 text-[10px] text-[#8b949e]">
                <span class="px-1.5 py-0.5 rounded-full bg-[#0096FF]/15 text-[#0096FF] font-medium uppercase tracking-wide">Cursor</span>
                <span>@dev-user</span>
                <span class="text-[#30363d]">&middot;</span>
                <span>Mar 7, 2026</span>
              </div>
            </div>
          </div>
          <!-- Footer benefits -->
          <div class="flex items-center justify-between px-4 py-2.5 border-t border-[#30363d] bg-[#161b22] text-[10px] text-[#8b949e]">
            <div class="flex items-center gap-3">
              <span class="flex items-center gap-1">
                <svg class="w-3 h-3 text-[#3fb950]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Free hosting
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-3 h-3 text-[#3fb950]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                You own it
              </span>
              <span class="flex items-center gap-1">
                <svg class="w-3 h-3 text-[#3fb950]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg>
                Delete anytime
              </span>
            </div>
            <a href="/explore" class="text-[#3fb950] hover:underline">Explore all &rarr;</a>
          </div>
        </div>
      </div>

    </div>

    <!-- Section CTA -->
    <div class="mt-24 text-center">
      <p class="text-text-secondary text-lg mb-6">Try it on your own sessions &mdash; takes 10 seconds.</p>
      <div class="group relative inline-block">
        <div class="absolute -inset-0.5 bg-gradient-to-r from-accent/50 to-cyan-400/50 rounded-lg blur opacity-40 group-hover:opacity-60 transition"></div>
        <button
          id="hiw-copy-btn"
          class="relative flex items-center gap-3 px-6 py-3.5 bg-surface-1 border border-border rounded-lg font-mono text-base hover:border-accent/50 transition-all cursor-pointer"
        >
          <span class="text-text-muted select-none">$</span>
          <span class="text-text-primary">npx vibe-replay</span>
          <svg id="hiw-copy-icon" class="w-4 h-4 text-text-muted hover:text-accent transition-colors ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/>
          </svg>
          <svg id="hiw-check-icon" class="w-4 h-4 text-accent ml-2 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <polyline points="20 6 9 17 4 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

<script>
  document.getElementById("hiw-copy-btn")?.addEventListener("click", () => {
    navigator.clipboard.writeText("npx vibe-replay").then(() => {
      const copyIcon = document.getElementById("hiw-copy-icon");
      const checkIcon = document.getElementById("hiw-check-icon");
      if (copyIcon && checkIcon) {
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");
        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 2000);
      }
    }).catch(() => {});
  });
</script>
  </div>
</section>
