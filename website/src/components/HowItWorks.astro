---
---

<section id="how-it-works" class="relative py-16 md:py-20 px-6">
  <div class="max-w-5xl mx-auto">
    <!-- Section header -->
    <div class="text-center mb-10 md:mb-20">
      <span class="block text-accent/70 font-mono text-sm font-medium tracking-wider uppercase mb-3">How it works</span>
      <h2 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight">
        One command, full context
      </h2>
      <p class="mt-4 text-text-secondary text-lg max-w-2xl mx-auto">PR diffs show <em>what</em> changed. vibe-replay shows <em>why</em> &mdash; every prompt, every thought, every edit, in one shareable file.</p>
    </div>

    <!-- Steps -->
    <div class="space-y-24">

      <!-- Step 1: Dashboard -->
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="md:w-2/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/10 to-cyan-400/5 flex items-center justify-center text-accent font-mono text-sm font-bold">1</span>
            <h3 class="text-xl font-semibold">All your sessions, one place</h3>
          </div>
          <p class="text-text-secondary leading-relaxed">A local dashboard shows every session across <span class="text-[#D97706] font-medium">Claude Code</span> and <span class="text-[#0096FF] font-medium">Cursor</span> &mdash; with activity heatmaps, project-level analytics, cost totals, and session counts. Runs entirely on your machine.</p>
          <p class="text-text-muted text-sm mt-3 font-mono">$ npx vibe-replay -d</p>
        </div>
        <div class="md:w-3/5">
          <div class="rounded-xl border border-border/50 overflow-hidden shadow-lg shadow-accent/5">
            <img
              src="/screenshots/dashboard.png"
              alt="vibe-replay dashboard — activity heatmap, project analytics, session overview"
              class="w-full block"
              loading="lazy"
              width="1372"
              height="878"
            />
          </div>
        </div>
      </div>

      <!-- Step 2: Insights -->
      <div class="flex flex-col md:flex-row-reverse items-center gap-10">
        <div class="md:w-2/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/10 to-cyan-400/5 flex items-center justify-center text-accent font-mono text-sm font-bold">2</span>
            <h3 class="text-xl font-semibold">Deep insights for every session</h3>
          </div>
          <p class="text-text-secondary leading-relaxed">Auto-generated analytics: token burn &amp; cost per turn, context window usage, cache hit rates, tool call distribution, sub-agent delegation, and file impact tracking. Know exactly what each session costs.</p>
        </div>
        <div class="md:w-3/5">
          <div class="rounded-xl border border-border/50 overflow-hidden shadow-lg shadow-accent/5">
            <img
              src="/screenshots/insights.png"
              alt="Session insights — token burn charts, cache hit rates, context window usage, tool call breakdown"
              class="w-full block"
              loading="lazy"
              width="1372"
              height="878"
            />
          </div>
        </div>
      </div>

      <!-- Step 3: Interactive replay -->
      <div class="flex flex-col md:flex-row items-center gap-10">
        <div class="md:w-2/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/10 to-cyan-400/5 flex items-center justify-center text-accent font-mono text-sm font-bold">3</span>
            <h3 class="text-xl font-semibold">Watch the full replay</h3>
          </div>
          <p class="text-text-secondary leading-relaxed">Step through every prompt, thinking block, tool call, and code diff. Three view modes &mdash; <strong>All</strong> (full detail), <strong>Compact</strong> (condensed), and <strong>Custom</strong> (your filters). Navigate with the outline sidebar, search, or playback controls.</p>
        </div>
        <div class="md:w-3/5">
          <div class="rounded-xl border border-border/50 overflow-hidden shadow-lg shadow-accent/5">
            <img
              src="/screenshots/tool-calls.png"
              alt="Interactive replay — syntax-highlighted diffs, tool calls, thinking blocks with outline navigation"
              class="w-full block"
              loading="lazy"
              width="1372"
              height="878"
            />
          </div>
        </div>
      </div>

      <!-- Step 4: Export & Share -->
      <div class="flex flex-col md:flex-row-reverse items-center gap-10">
        <div class="md:w-2/5">
          <div class="flex items-center gap-3 mb-4">
            <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-accent/10 to-cyan-400/5 flex items-center justify-center text-accent font-mono text-sm font-bold">4</span>
            <h3 class="text-xl font-semibold">Share anywhere</h3>
          </div>
          <p class="text-text-secondary leading-relaxed">Export as a self-contained HTML file, animated SVG, GIF, or markdown summary. Publish to GitHub Gist for a shareable link on <a href="/explore" class="text-accent hover:underline">vibe-replay.com</a>, or upload to the cloud. Everything works offline &mdash; zero external requests.</p>
          <!-- Export format badges -->
          <div class="flex flex-wrap gap-2 mt-4">
            <span class="px-2.5 py-1 rounded-md bg-accent/10 text-accent text-xs font-mono font-medium">HTML</span>
            <span class="px-2.5 py-1 rounded-md bg-[#d29922]/15 text-[#d29922] text-xs font-mono font-medium">SVG</span>
            <span class="px-2.5 py-1 rounded-md bg-[#58a6ff]/15 text-[#58a6ff] text-xs font-mono font-medium">GIF</span>
            <span class="px-2.5 py-1 rounded-md bg-[#bc8cff]/15 text-[#bc8cff] text-xs font-mono font-medium">Markdown</span>
            <span class="px-2.5 py-1 rounded-md bg-[#e6edf3]/10 text-[#e6edf3] text-xs font-mono font-medium">Gist</span>
            <span class="px-2.5 py-1 rounded-md bg-[#3fb950]/10 text-[#3fb950] text-xs font-mono font-medium">Cloud</span>
          </div>
        </div>
        <div class="md:w-3/5">
          <img
            src="/session-preview-demo.svg"
            alt="Animated SVG preview — embeddable session preview for PRs and READMEs"
            class="w-full rounded-xl border border-border/50"
            loading="lazy"
          />
        </div>
      </div>

    </div>

    <!-- Section CTA -->
    <div class="mt-12 md:mt-24 text-center">
      <p class="text-text-secondary text-lg mb-6">Try it on your own sessions &mdash; takes 10 seconds.</p>
      <div class="group relative inline-block">
        <div class="absolute -inset-0.5 bg-gradient-to-r from-accent/50 to-cyan-400/50 rounded-lg blur opacity-40 group-hover:opacity-60 transition"></div>
        <button
          id="hiw-copy-btn"
          class="relative flex items-center gap-3 px-6 py-3.5 bg-surface-1 border border-border rounded-lg font-mono text-base hover:border-accent/50 transition-all cursor-pointer"
        >
          <span class="text-text-muted select-none">$</span>
          <span class="text-text-primary">npx vibe-replay</span>
          <svg id="hiw-copy-icon" class="w-4 h-4 text-text-muted hover:text-accent transition-colors ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2" stroke-width="2"/>
            <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1" stroke-width="2"/>
          </svg>
          <svg id="hiw-check-icon" class="w-4 h-4 text-accent ml-2 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <polyline points="20 6 9 17 4 12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>

<script>
  document.getElementById("hiw-copy-btn")?.addEventListener("click", () => {
    navigator.clipboard.writeText("npx vibe-replay").then(() => {
      const copyIcon = document.getElementById("hiw-copy-icon");
      const checkIcon = document.getElementById("hiw-check-icon");
      if (copyIcon && checkIcon) {
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");
        setTimeout(() => {
          copyIcon.classList.remove("hidden");
          checkIcon.classList.add("hidden");
        }, 2000);
      }
    }).catch(() => {
      const input = document.createElement("input");
      input.value = "npx vibe-replay";
      document.body.appendChild(input);
      input.select();
      document.execCommand("copy");
      document.body.removeChild(input);
      const copyIcon = document.getElementById("hiw-copy-icon");
      const checkIcon = document.getElementById("hiw-check-icon");
      if (copyIcon && checkIcon) {
        copyIcon.classList.add("hidden");
        checkIcon.classList.remove("hidden");
        setTimeout(() => { copyIcon.classList.remove("hidden"); checkIcon.classList.add("hidden"); }, 2000);
      }
    });
  });
</script>
  </div>
</section>
